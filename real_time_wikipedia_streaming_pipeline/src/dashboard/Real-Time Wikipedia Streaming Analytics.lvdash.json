{
  "datasets": [
    {
      "name": "1a113561",
      "displayName": "Chart_1_Real_Time_Edits_(Line Chart)",
      "queryLines": [
        "SELECT *\n",
        "FROM real_time_wikipedia_streaming_pipeline.gold.edits_over_time\n",
        "ORDER BY edit_minute"
      ],
      "catalog": "real_time_wikipedia_streaming_pipeline",
      "schema": "gold"
    },
    {
      "name": "b9b663b8",
      "displayName": "Chart_2_Wiki_Activity_(Bar Chart)",
      "queryLines": [
        "\n",
        "SELECT *\n",
        "FROM wiki_edit_counts\n",
        "ORDER BY total_edits DESC"
      ],
      "catalog": "real_time_wikipedia_streaming_pipeline",
      "schema": "gold"
    },
    {
      "name": "5ac9c73f",
      "displayName": "Chart_3_Top_Users_(Bar Chart)",
      "queryLines": [
        "SELECT *\n",
        "FROM top_users"
      ],
      "catalog": "real_time_wikipedia_streaming_pipeline",
      "schema": "gold"
    },
    {
      "name": "33ad0af6",
      "displayName": "Chart_4_Top_Pages_(Table)",
      "queryLines": [
        "SELECT *\n",
        "FROM top_pages"
      ],
      "catalog": "real_time_wikipedia_streaming_pipeline",
      "schema": "gold"
    }
  ],
  "pages": [
    {
      "name": "b68363f6",
      "displayName": "Real-Time Wikipedia Streaming Analytics",
      "layout": [
        {
          "widget": {
            "name": "chart-1-real-time-edits-line-chart",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "1a113561",
                  "fields": [
                    {
                      "name": "monthly(edit_minute)",
                      "expression": "DATE_TRUNC(\"MONTH\", `edit_minute`)"
                    },
                    {
                      "name": "sum(edits)",
                      "expression": "SUM(`edits`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "showTitle": true,
                "title": "Chart 1 — Real-Time Edits (Line Chart)\n"
              },
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "monthly(edit_minute)",
                  "scale": {
                    "type": "temporal"
                  }
                },
                "y": {
                  "fieldName": "sum(edits)",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 12,
            "height": 6
          }
        },
        {
          "widget": {
